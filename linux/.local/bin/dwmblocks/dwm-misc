#!/bin/sh

wifistatus="$(cat /sys/class/net/w*/operstate 2>/dev/null)"
cablestatus="$(cat /sys/class/net/e*/operstate 2> /dev/null)"
if [ "$wifistatus" = "up" -o "$cablestatus" = "up" ]; then
  wifi="直"
else
  wifi="睊"
fi

unread="$(find "${XDG_DATA_HOME:-$HOME/.local/share}"/mail/*/[Ii][Nn][Bb][Oo][Xx]/new/* -type f 2>/dev/null | wc -l)"
if [ "$unread" = "0" ]; then
  mail=""
else
  mail=" "
fi

c() {
  echo "$*" | sed 's/x/\*/g' | bc -l
}

echo "$wifi$mail"
