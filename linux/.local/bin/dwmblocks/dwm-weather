#!/bin/sh

weatherreport="${XDG_DATA_HOME:-$HOME/.local/share}/weatherreport"
getforecast() {
  wifistatus="$(cat /sys/class/net/w*/operstate 2>/dev/null)"
  cablestatus="$(cat /sys/class/net/e*/operstate 2> /dev/null)"
  if [ "$wifistatus" = "up" -o "$cablestatus" = "up" ]; then
    curl -sf "wttr.in/?m" >"$weatherreport" || exit 1
  else
    echo "not connected"
    exit 1
  fi
}

showweather() {
  printf "%s" "$(sed '16q;d' "$weatherreport" | grep -wo "[0-9]*%" | sort -rn | sed "s/^/爫 /g;1q" | tr -d '\n')"
  sed '13q;d' "$weatherreport" | grep -o "m\\([-+]\\)*[0-9]\\+" | sed 's/+//g' | sort -n -t 'm' -k 2n | sed -e 1b -e '$!d' | tr '\n|m' ' ' | awk '{print " ﰬ " $1 "°C","ﰵ " $2 "°C"}'
}

# if forecast is outdated and the computer is connected download a new weather report
[ "$(stat -c %y "$weatherreport" 2>/dev/null | cut -d' ' -f1)" = "$(date '+%Y-%m-%d')" ] || getforecast
showweather
