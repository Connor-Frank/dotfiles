#!/bin/sh

name="$(cat /etc/*-release | sed -n 1p)"

#ΎΑηΎΔλ ΎΠΛΎΘο ΎΑΣ ΎΑμΏθΦΤ ΎΑΞΎΑΝΎΕρ ΎΒβΎΒαΎΒΩ
w="ΎΒΩ cancel\nΎΑμ lock\nΎΒΝ suspend\nΎΑη reboot\nΎΑΣ shutdown"
c=$(echo $w | dmenu -c -p "ΎΘο power" -i -l 5)
if [ "$c" == "ΎΒΩ cancel" ]; then
  exit
fi

if [ "$name" = "NAME=\"Arch Linux\"" ]; then
  case "$c" in
    "ΎΑμ lock") slock;;
    "ΎΒΝ suspend") systemctl suspend;;
    "ΎΑη reboot") reboot;;
    "ΎΑΣ shutdown") shutdown now;;
  esac;
elif [ "$name" = "NAME=\"void\"" ]; then
  case "$c" in
    "ΎΑμ lock") slock;;
    "ΎΒΝ suspend") sudo zzz;;
    "ΎΑη reboot") sudo runit-init 6;;
    "ΎΑΣ shutdown") sudo runit-init 0;;
  esac;
fi
