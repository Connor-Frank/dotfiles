#!/bin/sh

echo "building all sudo make install-ed software"
returnto=$(pwd)
cd ~/dotfiles/linux/.local/src
for folder in *; do
  cd $folder
  pwd && echo
  make && sudo make clean install
  echo && cd ..
done;
cd $returnto && killall -q dwmblocks; setsid dwmblocks &
echo "all software has been built and dwmblocks has been restarted"
echo "press ENTER to exit"
read junk
