#!/bin/sh

nettraf() {
    sum=0
    for arg; do
        read -r i < "$arg"
        sum=$(( sum + i ))
    done
    cache=${XDG_CACHE_HOME:-$HOME/.cache}/${1##*/}
    [ -f "$cache" ] && read -r old < "$cache" || old=0
    printf %d\\n "$sum" > "$cache"
    printf %d\\n $(( sum - old ))
}

rx=$(nettraf /sys/class/net/[ew]*/statistics/rx_bytes)
tx=$(nettraf /sys/class/net/[ew]*/statistics/tx_bytes)

printf " %4sB 祝 %4sB\\n" $(numfmt --to=iec $rx) $(numfmt --to=iec $tx)
