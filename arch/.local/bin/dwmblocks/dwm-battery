#!/bin/sh

# https://www.nerdfonts.com/cheat-sheet
# nf-mdi icons

# loop through all attached batteries and format the info
for battery in /sys/class/power_supply/BAT?*; do
  # if non-first battery, print a space separator.
  [ -n "${capacity+x}" ] && printf " "
  # sets up the status and capacity
  case "$(cat "$battery/status")" in
    "Full") status="п¤¤" ;;
    "Discharging") status="п–‹" ;;
    "Charging") status="п®Ј" ;;
    "Not charging") status="п–‚" ;;
    "Unknown") status="п–ђ" ;;
  esac
  capacity=$(cat "$battery/capacity")

  #makes a warn variable if discharging and low
  [ "$status" = "п–‹" ] && [ "$capacity" -le 25 ] && warn="пІЌ"

  # more specific battery icons
  if [ "$status" = "п–‹" ]; then
    if [ "$capacity" -eq 100 ]; then
      status="п•ё"
    elif [ "$capacity" -ge 90 ]; then
      status="п–Ѓ"
    elif [ "$capacity" -ge 80 ]; then
      status="п–Ђ"
    elif [ "$capacity" -ge 70 ]; then
      status="п•ї"
    elif [ "$capacity" -ge 60 ]; then
      status="п•ѕ"
    elif [ "$capacity" -ge 50 ]; then
      status="п•Ѕ"
    elif [ "$capacity" -ge 40 ]; then
      status="п•ј"
    elif [ "$capacity" -ge 30 ]; then
      status="п•»"
    elif [ "$capacity" -ge 20 ]; then
      status="п•є"
    elif [ "$capacity" -ge 10 ]; then
      status="п•№"
    elif [ "$capacity" -ge 0 ]; then
      status="п–Ќ"
    fi
  fi

  # Prints the info
  printf "%s%s %d%%" "$status" "$warn" "$capacity"
  unset warn
done && exit 0
