#!/bin/sh

if [ -z "$1" ]; then
  echo "some possible devices:"
  find ~/ -maxdepth 1 -group root -type d
  echo "input name to unmount (mounted on "$HOME"/<name>):"
  read name
else
  name="$1"
fi

[ ! -d "$HOME"/"$name" ] && echo "directory "$HOME"/$name does not exist." && exit

sudo umount "$HOME"/"$name"
sudo cryptsetup luksClose "$name"
rmdir "$HOME"/"$name"
echo "device $name closed and unmounted from "$HOME"/$name"
