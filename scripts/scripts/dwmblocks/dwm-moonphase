#!/bin/sh

# Shows the current moon phase.

moonfile="${XDG_DATA_HOME:-$HOME/.local/share}/moonphase"

[ "$(stat -c %y "$moonfile" 2>/dev/null | cut -d' ' -f1)" = "$(date '+%Y-%m-%d')" ] || { curl -sf "wttr.in/?format=%m" > "$moonfile" || exit 1 ;}

icon="$(cat "$moonfile")"

case "$icon" in
	рЯМС) name="New" ; nficon="оП£";;
	рЯМТ) name="Waxing Crescent" ; nficon="оПК";;
	рЯМУ) name="First Quarter" ; nficon="оПО";;
	рЯМФ) name="Waxing Gibbous" ; nficon="оПС";;
	рЯМХ) name="Full" ; nficon="оПХ";;
	рЯМЦ) name="Waning Gibbous" ; nficon="оПШ";;
	рЯМЧ) name="Last Quarter" ; nficon="оПЬ";;
	рЯМШ) name="Waning Crescent" ; nficon="оПЯ";;
	*) exit 1 ;;
esac

echo "${nficon-?}"
