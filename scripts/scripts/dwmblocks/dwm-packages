#!/bin/sh

wifistatus="$(cat /sys/class/net/w*/operstate 2>/dev/null)"

if [ "$wifistatus" = "up" ]; then
  package_count=$(pacman -Q 2> /dev/null | wc -l)
  updates_arch=$(checkupdates 2> /dev/null | wc -l)
  updates_aur=$(yay -Qua --devel 2> /dev/null | wc -l)
  updates=$(($updates_arch + $updates_aur))
  if [ "$updates" -ge 1 ]; then
    echo "$package_count ´úĺ $updates ´úö"
  elif [ "$updates" -eq 0 ]; then
    echo "$package_count ´úĺ"
  fi
else
  package_count=$(pacman -Q 2> /dev/null | wc -l)
  echo "$package_count ´úĺ ´¬ę"
fi
