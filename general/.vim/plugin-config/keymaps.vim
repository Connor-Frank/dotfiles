" space-e to toggle tagbar
nmap <leader>e :TagbarToggle<CR>
" code formatting
noremap <leader>a :FormatCode<CR>
" markdown preview
nmap <leader>m <Plug>MarkdownPreview
" latex preview
nmap <leader>p :LLPStartPreview<CR>
" leader + / to comment/uncomment
nmap <leader>/ <Plug>NERDCommenterToggle
vmap <leader>/ <Plug>NERDCommenterToggle<CR>gv
" open file explorer (ranger) with <leader>f by default
