export VISUAL=vim
export EDITOR="$VISUAL"

# history in cache directory
HISTSIZE=10000000
SAVEHIST=10000000
HISTFILE=~/.cache/zsh/history

# macOS prompt
#PS1='%n@%m %1~ %# '

# prompt (with help from here: https://stackoverflow.com/a/12935606)
setopt prompt_subst
autoload -Uz vcs_info
zstyle ':vcs_info:*' stagedstr 'M'
zstyle ':vcs_info:*' unstagedstr 'M'
zstyle ':vcs_info:*' check-for-changes true
zstyle ':vcs_info:*' actionformats '%F{1}[%F{2}%b%F{3}|%F{1}%a%F{1}]%f'
zstyle ':vcs_info:*' formats \
  ' %F{1}[%F{6}%b%F{1}] %F{2}%c%F{3}%u%f'
  zstyle ':vcs_info:git*+set-message:*' hooks git-untracked
  zstyle ':vcs_info:*' enable git
  +vi-git-untracked() {
  if [[ $(git rev-parse --is-inside-work-tree 2> /dev/null) == 'true' ]] && \
    [[ $(git ls-files --other --directory --exclude-standard | sed q | wc -l | tr -d ' ') == 1 ]] ; then
      hook_com[unstaged]+='%F{5}??%f'
  fi
}

precmd () { vcs_info }
PROMPT='%F{1}[%F{2}%n%F{1}] %F{4}%1~${vcs_info_msg_0_} %f%# '

autoload edit-command-line; zle -N edit-command-line
bindkey '^e' edit-command-line

## plugins ##
source ~/.config/zsh/antigen.zsh
antigen use oh-my-zsh
antigen bundle git
antigen bundle zsh-users/zsh-autosuggestions
antigen bundle zsh-users/zsh-completions
antigen apply

alias code='code-insiders'
alias vs='code-insiders . && exit'

# creates a tmux session named as the current directory and containing two windows
function tmx {
  name="$(basename $PWD)"
  tmux new-session -d -s $name
  tmux new-window -d
  tmux attach-session -d -t $name
};

# my favorite way to run tty-clock
alias clock='tty-clock -s -c -f "%d.%m.%Y"'

# a cool clock i found (https://github.com/joshdk/tty-qlock)
alias textclock='~/sync/scripts/tty-qlock-1.0.0/./dist/qlock -on-color green'

# exa is a cooler ls command that is colored and has file/folder icons
unalias ls
alias ls='exa'

source ~/.config/zsh/fsh/fast-syntax-highlighting.plugin.zsh 2> /dev/null
[ -f ~/.local/options.zsh ] && source ~/.local/options.zsh
